# Ignore everything
*

# Whitelist: project config
!.gitignore
!CLAUDE.md
!package.json
!package-lock.json
!tsconfig.json
!esbuild.config.mjs
!vitest.config.ts
!e2e.sh
!manifest.json
!versions.json
!README.md
!LICENSE
!styles.css
!CHANGELOG.md
!CONTRIBUTING.md
!.editorconfig
!.npmrc
!version-bump.mjs

# Whitelist: GitHub workflows
!.github/
!.github/**

# Whitelist: docs
!docs/
!docs/**

# Whitelist: source code
!src/
!src/**

# Whitelist: seed vault (notes + obsidian config, not plugin build artifacts)
!seed-vault/
!seed-vault/**
seed-vault/.obsidian/plugins/second-thoughts/main.js
seed-vault/.obsidian/plugins/second-thoughts/manifest.json
seed-vault/.obsidian/plugins/second-thoughts/styles.css
seed-vault/.obsidian/plugins/second-thoughts/data.json
seed-vault/.obsidian/plugins/second-thoughts/embeddings/
seed-vault/.obsidian/workspace.json

